# ESP-IDF build artifacts
build/
sdkconfig
sdkconfig.old
managed_components/

# Binary outputs (generated; not source)
*.bin
*.elf
*.map

# Host test build directories
build_host/
host_test/build/
host_test/build_*/

# Web build output
# web/dist/index.html is committed (pre-built standalone SPA — works without npm build).
# Vite-generated assets and gzip files are NOT committed (regenerated by npm run build).
web/dist/assets/
web/dist/*.gz
web/dist/**/*.gz
web/node_modules/
web/.vite/
web/playwright-report/
web/test-results/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
/dist/           # top-level dist only (web/dist/ is intentionally committed)

# Security: NEVER commit secrets or credentials
*.env
.env.*
*token*.json
*token*.txt
*.pem
*.key
*secret*
*credential*
*password*.txt

# Chat/session transcript dumps — safety net against accidental inclusion
# (these live in the parent ST Thesis/ folder, NOT this repo, but guard anyway)
*chat*.md
*Chat*.md
*dump*.md
*Dump*.md
*transcript*.md
Claude*.md
cHAT*.md

# IDE / OS
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
