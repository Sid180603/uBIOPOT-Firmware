# Aqua-HMET sdkconfig.defaults — committed; drives idf.py configuration defaults.
# The generated `sdkconfig` is git-ignored (never commit sdkconfig itself).
# To regenerate: idf.py reconfigure

# ---- Flash ----
# Use the choice bool, NOT the derived string CONFIG_ESPTOOLPY_FLASHSIZE="4MB".
# In ESP-IDF Kconfig, setting the choice item (FLASHSIZE_4MB=y) is what drives
# the flash-size selection; the string is auto-derived from whichever choice is set.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# ---- Partition table ----
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# ---- FreeRTOS: dual-core (unicore = OFF for SMP, Core0=WiFi/UI, Core1=acquisition) ----
CONFIG_FREERTOS_UNICORE=n

# ---- FreeRTOS tick rate: 1000 Hz = 1 ms resolution ----
# Default is 100 Hz (10 ms/tick), which makes pdMS_TO_TICKS(2) = 0 (a no-op taskYIELD).
# ADS1115 averaging needs real 2 ms inter-sample gaps (1.7 conversion periods @860 SPS)
# to read independent samples. Without this, pstat_adc_read_current_uA averages
# identical values and gets zero noise reduction.
# 1000 Hz is standard practice for timing-sensitive ESP32 applications.
CONFIG_FREERTOS_HZ=1000

# ---- HTTP server: WebSocket support required for P5 ----
CONFIG_HTTPD_WS_SUPPORT=y

# ---- Default log level: WARN (overridden at runtime in P7 via esp_log_level_set) ----
CONFIG_LOG_DEFAULT_LEVEL_WARN=y

# ---- Main task stack (bytes) — bumped from default 3584 ----
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384

# ---- LVGL9 configuration (P4) ----
# Use FreeRTOS for LVGL thread safety (mutex + task notification).
# LVGL task will be pinned to Core 0 in ui_tft_start() to avoid Core 1 (acquisition).
CONFIG_LV_OS_FREERTOS=y

# Montserrat fonts: 14pt (hint bar / small UI), 20pt (labels/values), 28pt (big peak display).
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_LV_FONT_MONTSERRAT_28=y
# Default LVGL font = Montserrat 14.
CONFIG_LV_FONT_DEFAULT_MONTSERRAT_14=y

# LVGL memory: use ESP-IDF heap (CLIB) instead of LVGL's builtin 64 KB TLSF pool.
# 5 screens + scatter chart + 3 Montserrat fonts exceed 64 KB; the full heap has ~180 KB free.
CONFIG_LV_USE_CLIB_MALLOC=y
CONFIG_LV_USE_CLIB_STRING=y
CONFIG_LV_USE_CLIB_SPRINTF=y

# Color depth: 16-bit RGB565 to match ILI9341 panel.
# This is the Kconfig default but stated explicitly for clarity.
CONFIG_LV_COLOR_DEPTH_16=y
